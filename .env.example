# ── API ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/scopeform
REDIS_URL=redis://localhost:6379

# Signing key for Scopeform JWTs.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-hex-string
JWT_ALGORITHM=HS256

# REQUIRED — Fernet key used to encrypt provider API keys at rest.
# Adding an integration returns 503 until this is set.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Web (Next.js dashboard) ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
